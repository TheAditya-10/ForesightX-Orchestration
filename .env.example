SERVICE_NAME=foresightx-orchestration
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://username:password@hostname:5432/foresightx_orchestration
DATA_SERVICE_URL=http://localhost:8001
PROFILE_SERVICE_URL=http://localhost:8002
PATTERN_SERVICE_URL=http://localhost:8003

REQUEST_TIMEOUT_SECONDS=8
MAX_RETRIES=2
MAX_PORTFOLIO_EXPOSURE=0.20
HIGH_VOLATILITY_THRESHOLD=0.035

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
